# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Environment variables
.env
.env.*

# Flask instance and logs
instance/
*.log

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS and editor files
.DS_Store
.vscode/

# Runtime uploads (keep placeholder)
static/uploads/*
!static/uploads/.gitkeep
